# ==================================================================================
# B.L.A.Z.E Configuration Template
# ==================================================================================
# IMPORTANT: Copy this file to .env and fill in YOUR OWN API keys
# NEVER commit the .env file to GitHub!
# ==================================================================================

# ──────────────────────────────────────────────────────────────────────────────
# 🔴 REQUIRED - Get FREE from https://console.groq.com
# ──────────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ──────────────────────────────────────────────────────────────────────────────
# 🟡 OPTIONAL - Weather API
# Get FREE from https://openweathermap.org/api
# ──────────────────────────────────────────────────────────────────────────────
WEATHER_API_KEY=your_openweathermap_api_key_here

# ──────────────────────────────────────────────────────────────────────────────
# 🟡 OPTIONAL - News API
# Get FREE from https://newsapi.org
# ──────────────────────────────────────────────────────────────────────────────
NEWS_API_KEY=your_newsapi_key_here

# ──────────────────────────────────────────────────────────────────────────────
# 📍 City for Weather Queries
# ──────────────────────────────────────────────────────────────────────────────
BLAZE_CITY=

# ==================================================================================
# 🔐 SECURITY - Authentication & Access Control
# ==================================================================================
# Generate a strong random token for API authentication
# Use: python -c "import secrets; print(secrets.token_urlsafe(32))"
# ==================================================================================
API_TOKEN=your-secure-random-token-here

# Enable/disable authentication (true/false)
REQUIRE_AUTH=true

# IP whitelist (comma-separated, leave empty to allow all localhost)
# Example: 127.0.0.1,192.168.1.100
IP_WHITELIST=

# ==================================================================================
# 🔑 Key Storage (Optional - Advanced)
# ==================================================================================
# Leave empty to use default ~/.blaze/blaze.key
# For production, use external key management:
# - Windows: Use Windows Credential Manager
# - Linux: Use systemd user environment
# - macOS: Use Keychain
# ==================================================================================
BLAZE_KEY_PATH=

# ==================================================================================
# 📊 Server Configuration
# ==================================================================================
# Server host (0.0.0.0 = accessible from network, 127.0.0.1 = localhost only)
SERVER_HOST=127.0.0.1
SERVER_PORT=8000

# Enable HTTPS (requires certificate files)
ENABLE_HTTPS=false
CERT_FILE=
KEY_FILE=

# ==================================================================================
# 📝 Logging & Audit
# ==================================================================================
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Enable request logging
ENABLE_REQUEST_LOGGING=true

# Enable security audit logging
ENABLE_AUDIT_LOG=true

# ==================================================================================
# 🛡️ Rate Limiting
# ==================================================================================
# Maximum requests per minute
RATE_LIMIT_REQUESTS=100

# Time window in minutes
RATE_LIMIT_WINDOW=1

# ==================================================================================
# ⏱️ Session & Timeout
# ==================================================================================
# Session timeout in seconds (30 minutes = 1800)
SESSION_TIMEOUT=1800

# Max concurrent connections
MAX_CONNECTIONS=50

# ==================================================================================
# 🔍 Data & Privacy
# ==================================================================================
# Days to keep history before cleanup
HISTORY_RETENTION_DAYS=90

# Enable conversation encryption
ENCRYPT_CONVERSATIONS=true

# ==================================================================================
# 🚀 Development Mode (DO NOT ENABLE IN PRODUCTION)
# ==================================================================================
# Debug mode - shows detailed error messages
DEBUG_MODE=false

# Allow all origins (DANGEROUS - for development only)
ALLOW_ALL_ORIGINS=false

# ==================================================================================
# 📌 Notes
# ==================================================================================
# 1. Never commit this file with real values
# 2. Use .env.example as template for new installations
# 3. Set strong API_TOKEN for security
# 4. Review all settings before going to production
# 5. For Wi-Fi access, use IP_WHITELIST to restrict access
# ==================================================================================